{
  "ignorePatterns": [
    { "pattern": "^https://github.com/got-feedback/feedBack-plugin-spec/(releases|compare|issues|discussions)" },
    { "pattern": "^https://got-feedback.github.io/" },
    { "pattern": "^(plugin-spec-v1|best-practices|changelog)\\.md" },
    { "pattern": "^schemas/[a-z0-9-]+\\.schema\\.json$" }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "aliveStatusCodes": [200, 206, 301, 302, 403]
}
